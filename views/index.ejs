  <!-- ==================== ALUR LAYANAN ==================== -->
  <section class="flow section" id="alur">
    <div class="container">
      <span class="section-label flow-label">Langkah Demi Langkah</span>
      <h2 class="section-title flow-title">Alur Layanan Kami</h2>
      <div class="flow-steps">
        <div class="flow-step flow-step--dark">
          <div class="flow-step-num">01</div>
          <h3 class="flow-step-title">Hubungi Kami Untuk Penjemputan</h3>
          <p class="flow-step-desc">
            Jadwalkan janji temu perawatan profesional Anda dan kurir kami akan
            datang ke lokasi pilihan Anda.
          </p>
          <a href="#" class="flow-step-link">&rsaquo; Kontak</a>
        </div>
        <div class="flow-step flow-step--light">
          <div class="flow-step-num">02</div>
          <h3 class="flow-step-title">Sepatu Anda Kami Jemput</h3>
          <p class="flow-step-desc">
            Kami mengumpulkan item Anda dengan hati-hati dan memberikan tanda
            terima digital untuk pelacakan selama proses.
          </p>
          <a href="#" class="flow-step-link flow-step-link--orange">&rsaquo; Tanda Terima</a>
        </div>
        <div class="flow-step flow-step--light">
          <div class="flow-step-num">03</div>
          <h3 class="flow-step-title">Memulai proses pembersihan</h3>
          <p class="flow-step-desc">
            Spesialis kami melakukan perawatan yang dipilih menggunakan alat dan
            formula presisi tingkat tinggi.
          </p>
          <a href="#" class="flow-step-link flow-step-link--orange">&rsaquo; Detail Proses</a>
        </div>
        <div class="flow-step flow-step--light">
          <div class="flow-step-num">04</div>
          <h3 class="flow-step-title">Siap untuk dikirimkan kepada Anda</h3>
          <p class="flow-step-desc">
            Setelah restorasi selesai dan pemeriksaan kualitas dilakukan, kami
            mengembalikan item Anda ke depan pintu rumah Anda.
          </p>
          <a href="#" class="flow-step-link flow-step-link--orange">&rsaquo; Kontak</a>
        </div>
      </div>
    </div>
  </section>


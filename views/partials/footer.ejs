<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <!-- Brand Column -->
      <div class="footer-brand">
        <span class="logo footer-logo">GO<span class="logo-highlight">ED</span>E</span>
        <p>
          <%= settings.aboutText %>
        </p>

        <div class="social-links">
          <% if (settings.socialLinks?.instagram?.isActive) { %>
            <a href="<%= settings.socialLinks.instagram.url %>" class="social-btn" aria-label="Instagram"
              target="_blank">
              <i class="fa-brands fa-instagram" style="font-size: 20px;"></i>
            </a>
            <% } %>
              <% if (settings.socialLinks?.youtube?.isActive) { %>
                <a href="<%= settings.socialLinks.youtube.url %>" class="social-btn" aria-label="YouTube"
                  target="_blank">
                  <i class="fa-brands fa-youtube" style="font-size: 20px;"></i>
                </a>
                <% } %>
                  <% if (settings.socialLinks?.tiktok?.isActive) { %>
                    <a href="<%= settings.socialLinks.tiktok.url %>" class="social-btn" aria-label="TikTok"
                      target="_blank">
                      <i class="fa-brands fa-tiktok" style="font-size: 20px;"></i>
                    </a>
                    <% } %>
                      <% if (settings.socialLinks?.facebook?.isActive) { %>
                        <a href="<%= settings.socialLinks.facebook.url %>" class="social-btn" aria-label="Facebook"
                          target="_blank">
                          <i class="fa-brands fa-facebook" style="font-size: 20px;"></i>
                        </a>
                        <% } %>
        </div>
      </div>

      <!-- Layanan Column -->
      <div class="footer-col">
        <h4>Layanan</h4>
        <ul>
          <% if (typeof serviceCategories !=='undefined' && serviceCategories.length> 0) { %>
            <% serviceCategories.forEach(cat=> { %>
              <li><a href="#">
                  <%= cat %>
                </a></li>
              <% }); %>
                <% } else { %>
                  <li><a href="#">Pembersihan Sepatu</a></li>
                  <li><a href="#">Cat Ulang Artistik</a></li>
                  <li><a href="#">Restorasi Tas</a></li>
                  <li><a href="#">Perawatan Helm</a></li>
                  <% } %>
        </ul>
      </div>

      <!-- Hubungi Kami Column -->
      <div class="footer-col">
        <h4>Hubungi Kami</h4>
        <ul class="footer-contact">
          <li>
            <div class="contact-item">
              <span class="contact-icon-img">
                <i class="fa-brands fa-whatsapp" style="font-size: 20px;"></i>
              </span>
              <div>
                <span class="contact-label">WhatsApp</span>
                <span class="contact-value">
                  <%= settings.storeInfo.phone %>
                </span>
              </div>
            </div>
          </li>
          <li>
            <div class="contact-item">
              <span class="contact-icon-img">
                <i class="fa-regular fa-envelope" style="font-size: 20px;"></i>
              </span>
              <div>
                <span class="contact-label">Email</span>
                <span class="contact-value">
                  <%= settings.storeInfo.email %>
                </span>
              </div>
            </div>
          </li>
          <li>
            <div class="contact-item">
              <span class="contact-icon-img">
                <i class="fa-solid fa-location-dot" style="font-size: 20px;"></i>
              </span>
              <div>
                <span class="contact-label">Alamat Toko</span>
                <span class="contact-value">
                  <%= settings.storeInfo.name %>
                </span>
                <span class="contact-sub-value" style="display: block; font-size: 11px; opacity: 0.7; margin-top: 2px;">
                  <%= settings.storeInfo.address %>
                </span>
              </div>
            </div>
          </li>
        </ul>
      </div>

      <!-- Jam Operasional Column -->
      <div class="footer-col">
        <h4>Jam Operasional</h4>
        <ul class="footer-hours">
          <li>
            <span class="hours-day">Setiap Hari</span>
            <span class="hours-time">
              <%= settings.storeInfo.openTime %> – <%= settings.storeInfo.closeTime %>
            </span>
          </li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <div class="footer-bottom-links">
        <a href="#">Privasi</a>
        <a href="#">Ketentuan</a>
        <a href="#">Keberlanjutan</a>
      </div>
      <span>© Adrian Yudhaswara, Muhammad Ziyad Fauzan, Ibrahim</span>
    </div>
  </div>
</footer>

<script src="/js/main.js"></script>
</body>

</html>
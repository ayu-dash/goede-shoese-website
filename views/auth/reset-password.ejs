<%- include('../partials/header') %>

<!-- RESET PASSWORD PAGE -->
<section class="auth-minimal-page">
  <div class="auth-minimal-card">
    <h1 class="auth-minimal-title">Atur Ulang Kata Sandi</h1>
    <p class="auth-minimal-desc">Masukkan kata sandi baru Anda untuk mengamankan akun.</p>

    <form action="/reset-password" method="POST" class="auth-form" id="reset-form">
      <!-- Kata Sandi Baru -->
      <div class="form-group">
        <label for="newPassword" class="form-label">Kata Sandi Baru</label>
        <div class="form-input-wrap form-input-icon">
          <i class="fa-solid fa-lock input-icon"></i>
          <input type="password" id="newPassword" name="newPassword" class="form-input form-input--icon" placeholder="Min. 8 karakter" required />
          <button type="button" class="password-toggle" aria-label="Toggle password visibility">
            <i class="fa-regular fa-eye"></i>
          </button>
        </div>
      </div>

      <!-- Konfirmasi Kata Sandi Baru -->
      <div class="form-group">
        <label for="confirmNewPassword" class="form-label">Konfirmasi Kata Sandi Baru</label>
        <div class="form-input-wrap form-input-icon">
          <i class="fa-solid fa-lock input-icon"></i>
          <input type="password" id="confirmNewPassword" name="confirmNewPassword" class="form-input form-input--icon" placeholder="Ulangi kata sandi" required />
          <button type="button" class="password-toggle" aria-label="Toggle password visibility">
            <i class="fa-regular fa-eye-slash"></i>
          </button>
        </div>
      </div>

      <button type="submit" class="btn btn-primary btn-auth btn-auth--compact" id="btn-reset">Simpan Kata Sandi Baru</button>
    </form>
  </div>
</section>

<%- include('../partials/footer') %>

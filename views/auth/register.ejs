<%- include('../partials/header') %>

  <!-- REGISTER PAGE -->
  <section class="auth-page">
    <div class="auth-layout">
      <!-- Left: Hero Image Section -->
      <div class="auth-hero">
        <img src="/images/auth-register.png" alt="Goede Shoes" class="auth-hero-img" />
        <div class="auth-hero-overlay"></div>
        <div class="auth-hero-content">
          <span class="auth-hero-label">KUALITAS TANPA KOMPROMI</span>
          <h2 class="auth-hero-title">Setiap Langkah Adalah <br>Pernyataan.</h2>
          <p class="auth-hero-desc">Di Goede, kami tidak hanya membersihkan sepatu, kami merestorasi kepercayaan diri
            Anda melalui presisi yang tak tertanding.</p>
        </div>
      </div>

      <!-- Right: Form Section -->
      <div class="auth-form-section">
        <div class="auth-form-wrapper">
          <h1 class="auth-form-title">Buat Akun</h1>
          <p class="auth-form-subtitle">Bergabunglah dengan standar baru dalam perawatan sepatu eksklusif.</p>

          <form id="register-form" class="auth-form">
            <!-- Nama Lengkap -->
            <div class="form-group">
              <label for="nama" class="form-label">Nama Lengkap</label>
              <div class="form-input-wrap">
                <input type="text" id="nama" name="name" class="form-input" placeholder="John Doe" required />
              </div>
            </div>

            <!-- Email -->
            <div class="form-group">
              <label for="email" class="form-label">Email</label>
              <div class="form-input-wrap">
                <input type="email" id="email" name="email" class="form-input" placeholder="nama@email.com" required />
              </div>
            </div>

            <!-- Nomor Telepon -->
            <div class="form-group">
              <label for="phone" class="form-label">Nomor Telepon</label>
              <div class="form-input-wrap">
                <input type="tel" id="phone" name="phone" class="form-input" placeholder="081234567890" 
                  pattern="^(08|628|\+628)[0-9]{8,12}$" 
                  title="Gunakan format nomor Indonesia (Contoh: 0812..., 62812..., atau +62812...)" 
                  required />
              </div>
            </div>


            <!-- Kata Sandi -->
            <div class="form-group">
              <label for="password" class="form-label">Kata Sandi</label>
              <div class="form-input-wrap">
                <input type="password" id="password" name="password" class="form-input" placeholder="••••••••"
                  required />
              </div>
            </div>

            <!-- Ulangi Kata Sandi -->
            <div class="form-group">
              <label for="confirmPassword" class="form-label">Ulangi Kata Sandi</label>
              <div class="form-input-wrap">
                <input type="password" id="confirmPassword" name="confirmPassword" class="form-input"
                  placeholder="••••••••" required />
              </div>
            </div>

            <!-- Terms Checkbox -->
            <div class="form-check">
              <input type="checkbox" id="terms" name="terms" class="form-checkbox" required />
              <label for="terms" class="form-check-label">
                Saya setuju dengan <a href="#" class="form-link">Syarat & Ketentuan</a> serta kebijakan <a href="#"
                  class="form-link">Privasi Goede</a>
              </label>
            </div>

            <!-- Submit -->
            <button type="submit" class="btn btn-primary btn-auth" id="btn-register">Daftar Sekarang</button>
          </form>

          <script>
            document.getElementById('register-form').addEventListener('submit', async (e) => {
              e.preventDefault();
              const btn = document.getElementById('btn-register');
              btn.disabled = true;
              btn.textContent = 'Sedang Memproses...';

              const formData = new FormData(e.target);
              const data = Object.fromEntries(formData.entries());

              if (data.password !== data.confirmPassword) {
                alert('Kata sandi tidak cocok!');
                btn.disabled = false;
                btn.textContent = 'Daftar Sekarang';
                return;
              }

              // Phone validation
              const phoneRegex = /^(08|628|\+628)[0-9]{8,12}$/;
              if (!phoneRegex.test(data.phone)) {
                alert('Format nomor telepon tidak valid! Gunakan format Indonesia (contoh: 081234567890).');
                btn.disabled = false;
                btn.textContent = 'Daftar Sekarang';
                return;
              }


              try {
                const res = await fetch('/api/auth/register', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify(data)
                });

                const result = await res.json();
                if (result.status === 'success') {
                  localStorage.setItem('tempEmail', data.email);
                  window.location.href = '/verify';
                } else {
                  alert(result.message);
                }
              } catch (err) {
                alert('Terjadi kesalahan, silakan coba lagi.');
              } finally {
                btn.disabled = false;
                btn.textContent = 'Daftar Sekarang';
              }
            });
          </script>


          <p class="auth-switch">Sudah punya akun? <a href="/login" class="auth-switch-link">Masuk</a></p>
        </div>
      </div>
    </div>
  </section>

  <%- include('../partials/footer') %>
<%- include('../partials/dashboard-head') %>

<div class="admin-panel">
  <div class="admin-panel-header">
    <h3 class="admin-panel-title">Antrian Cuci Sepatu</h3>
    <p class="admin-panel-subtitle">MANAJEMEN OPERASIONAL PENCUCIAN</p>
  </div>

  <div class="admin-table-container">
    <table class="admin-table">
      <thead>
        <tr>
          <th>ORDER ID</th>
          <th>CUSTOMER</th>
          <th>ITEM</th>
          <th>LAYANAN</th>
          <th>METODE BAYAR</th>
          <th>TGL MASUK</th>
          <th>TENGGAT</th>
          <th>STATUS</th>
          <th>AKSI</th>
        </tr>
      </thead>
      <tbody>
        <% if (orders && orders.length > 0) { %>
          <% orders.forEach(order => { %>
            <tr>
              <td style="font-weight: 700; color: var(--navy);"><%= order.orderId %></td>
              <td>
                <span class="table-client-name"><%= order.user ? order.user.name : 'Unknown' %></span>
              </td>
              <td>
                <div style="display: flex; flex-direction: column; gap: 4px;">
                  <% order.items.forEach(item => { %>
                    <span class="table-client-sub" style="font-weight: 600; color: var(--text-primary); display: block;">
                      • <%= item.shoeName %>
                    </span>
                  <% }) %>
                </div>
              </td>
              <td>
                <div style="display: flex; flex-direction: column; gap: 4px;">
                  <% order.items.forEach(item => { %>
                    <div>
                      <span class="badge badge-layanan-blue" style="font-size: 10px; padding: 2px 6px;">
                        <%= item.serviceType %>
                      </span>
                    </div>
                  <% }) %>
                </div>
              </td>
              <td>
                <span class="badge badge-layanan-gray" style="color: var(--navy); border: 1px solid var(--navy); text-transform: uppercase;">
                  <%= order.payment.method %>
                </span>
              </td>
              <td>
                <span class="table-client-sub"><%= new Date(order.createdAt).toLocaleDateString('id-ID', { day: '2-digit', month: 'short' }) %></span>
              </td>
              <td>
                <% 
                  const entryDate = new Date(order.createdAt);
                  const deadline = new Date(entryDate);
                  deadline.setDate(entryDate.getDate() + 3); // Default 3 hari
                  const isOverdue = new Date() > deadline;
                %>
                <span class="table-client-sub <%= isOverdue ? 'text-overdue' : '' %>" style="font-weight: 600;">
                  <%= deadline.toLocaleDateString('id-ID', { day: '2-digit', month: 'short' }) %>
                </span>
              </td>
              <td>
                <% if (order.status === 'pending') { %>
                  <span class="badge badge-pending" style="background: #fef3c7; color: #92400e;">Menunggu Drop-off</span>
                <% } else if (order.status === 'received') { %>
                  <span class="badge badge-pending">Siap Dicuci</span>
                <% } else if (order.status === 'validating-in') { %>
                  <span class="badge badge-processing">Cek Kondisi</span>
                <% } else if (order.status === 'in-progress') { %>
                  <span class="badge badge-processing">Sedang Dicuci</span>
                <% } else { %>
                  <span class="badge badge-processing"><%= order.status.toUpperCase() %></span>
                <% } %>
              </td>
              <td>
                <a href="/staff/order/<%= order._id %>" class="btn btn-primary btn-sm">
                  Detail
                </a>
              </td>
            </tr>
          <% }); %>
        <% } else { %>
          <tr>
            <td colspan="9" style="text-align: center; padding: 3rem; color: var(--text-secondary);">
              Tidak ada antrian cuci saat ini.
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>



<%- include('../partials/dashboard-foot') %>

<%- include('../partials/dashboard-head') %>

<div class="page-header" style="margin-bottom: 32px">
  <h1 class="page-title page-title--xl">Laporan Transaksi</h1>
  <div class="header-actions">
    <div class="revenue-summary">
        <span class="label">TOTAL REVENUE (SELECTED RANGE)</span>
        <span class="value">Rp <%= totalRevenue.toLocaleString("id-ID") %></span>
    </div>
  </div>
</div>

<!-- FILTER BAR -->
<div class="admin-panel" style="margin-bottom: 24px; padding: 20px;">
    <form action="/admin/transactions" method="GET" class="transaction-filter-form">
        <div class="filter-group">
            <div class="input-field">
                <label>Dari Tanggal</label>
                <input type="date" name="startDate" value="<%= startDate %>" class="modal-input">
            </div>
            <div class="input-field">
                <label>Sampai Tanggal</label>
                <input type="date" name="endDate" value="<%= endDate %>" class="modal-input">
            </div>
            <div class="filter-actions">
                <button type="submit" class="btn btn-primary">
                    <i class="fa-solid fa-filter"></i> Filter Laporan
                </button>
                <a href="/admin/transactions" class="btn btn-ghost-reset">Reset</a>
            </div>
        </div>
    </form>
</div>

<!-- TRANSACTIONS TABLE -->
<div class="admin-panel">
    <div class="admin-table-wrapper" style="overflow-x: auto">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>ORDER ID</th>
                    <th>TANGGAL</th>
                    <th>CUSTOMER</th>
                    <th>LAYANAN</th>
                    <th>TOTAL</th>
                    <th>STATUS</th>
                    <th style="text-align: right">AKSI</th>
                </tr>
            </thead>
            <tbody>
                <% if (orders && orders.length > 0) { %>
                    <% orders.forEach(order => { %>
                        <tr>
                            <td style="font-weight: 700;">
                                <%= order.orderId %>
                            </td>
                            <td>
                                <span style="font-size: 13px; font-weight: 500;">
                                    <%= new Date(order.createdAt).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                                </span>
                                <span style="display: block; font-size: 11px; color: #94a3b8;">
                                    <%= new Date(order.createdAt).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' }) %>
                                </span>
                            </td>
                            <td>
                                <div class="table-client-info">
                                    <img src="https://ui-avatars.com/api/?name=<%= encodeURIComponent(order.user ? order.user.name : 'Unknown') %>&background=random" class="table-client-avatar" alt="User">
                                    <div>
                                        <span class="table-client-name"><%= order.user ? order.user.name : "Deleted User" %></span>
                                        <span class="table-client-sub"><%= order.user ? order.user.email : "-" %></span>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <% if (order.items && order.items.length > 0) { %>
                                    <span class="badge badge-layanan-blue" style="font-size: 10px;">
                                        <%= order.items[0].serviceType %>
                                    </span>
                                    <% if (order.items.length > 1) { %>
                                        <span style="font-size: 11px; color: #64748b; margin-left: 4px;">+<%= order.items.length - 1 %> more</span>
                                    <% } %>
                                <% } else { %>
                                    -
                                <% } %>
                            </td>
                            <td>
                                <span style="font-weight: 700; color: var(--navy-dark)">
                                    Rp <%= order.totalPrice.toLocaleString("id-ID") %>
                                </span>
                            </td>
                            <td>
                                <% if (order.status === 'completed') { %>
                                    <span class="badge badge-completed">Completed</span>
                                <% } else if (order.status === 'pending') { %>
                                    <span class="badge badge-pending">Pending</span>
                                <% } else if (order.status === 'cancelled') { %>
                                    <span class="badge badge-pending" style="background:#fee2e2;color:#b91c1c;">Cancelled</span>
                                <% } else { %>
                                    <span class="badge badge-processing">
                                        <%= order.status.charAt(0).toUpperCase() + order.status.slice(1).replace('-', ' ') %>
                                    </span>
                                <% } %>
                            </td>
                            <td style="text-align: right;">
                                <button class="btn btn-icon" onclick="window.location.href='/staff/order/<%= order._id %>'" title="Detail">
                                    <i class="fa-solid fa-eye"></i>
                                </button>
                            </td>
                        </tr>
                    <% }); %>
                <% } else { %>
                    <tr>
                        <td colspan="7" style="text-align: center; padding: 4rem; color: var(--text-secondary);">
                            <div style="opacity: 0.5; margin-bottom: 12px;">
                                <i class="fa-solid fa-receipt fa-3x"></i>
                            </div>
                            <p>Tidak ada data transaksi yang ditemukan.</p>
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<%- include('../partials/dashboard-foot') %>

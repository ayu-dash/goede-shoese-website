<%- include('../partials/dashboard-head') %>

<div class="page-header" style="margin-bottom: 32px">
  <h1 class="page-title page-title--xl">Manajemen Customer</h1>
</div>

<!-- STATS CARDS -->
<div
  class="admin-stats-grid"
  style="grid-template-columns: repeat(3, 1fr); margin-bottom: 32px"
>
  <div class="admin-stat-card">
    <div
      style="
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 16px;
      "
    >
      <div
        class="stat-icon"
        style="
          background: #e0e7ff;
          color: #3730a3;
          padding: 8px 12px;
          border-radius: 8px;
        "
      >
        <i class="fa-solid fa-user-group"></i>
      </div>
      <div class="badge" style="background: #dcfce7; color: #16a34a">+12%</div>
    </div>
    <div>
      <div class="stat-label">Total Customer</div>
      <div class="stat-value" id="statTotal"><%= stats.total %></div>
    </div>
  </div>

  <div class="admin-stat-card">
    <div
      style="
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 16px;
      "
    >
      <div
        class="stat-icon"
        style="
          background: #f1f3f5;
          color: var(--navy-dark);
          padding: 8px 12px;
          border-radius: 8px;
        "
      >
        <i class="fa-solid fa-bolt"></i>
      </div>
      <div class="badge" style="background: #e0e7ff; color: #3730a3">
        Bulan Ini
      </div>
    </div>
    <div>
      <div class="stat-label">Aktif</div>
      <div class="stat-value" id="statActive"><%= stats.active %></div>
    </div>
  </div>

  <div class="admin-stat-card">
    <div
      style="
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 16px;
      "
    >
      <div
        class="stat-icon"
        style="
          background: #ffedd5;
          color: #ea580c;
          padding: 8px 12px;
          border-radius: 8px;
        "
      >
        <i class="fa-solid fa-money-bill-1-wave"></i>
      </div>
    </div>
    <div>
      <div class="stat-label">Tidak Aktif</div>
      <div class="stat-value" id="statInactive"><%= stats.inactive %></div>
    </div>
  </div>
</div>

<!-- CUSTOMER TABLE -->
<div class="admin-panel">
  <div class="filter-bar">
    <div class="search-wrapper">
      <i class="fa-solid fa-magnifying-glass"></i>
      <input
        type="text"
        id="customerSearch"
        class="search-input"
        placeholder="Filter berdasarkan nama..."
      />
    </div>
  </div>

  <div class="admin-table-wrapper" style="overflow-x: auto">
    <table class="admin-table">
      <thead>
        <tr>
          <th>NAMA LENGKAP</th>
          <th>KONTAK</th>
          <th>TOTAL PESANAN</th>
          <th>TOTAL TRANSAKSI</th>
          <th>STATUS</th>
          <th>TANGGAL BERGABUNG</th>
          <th style="text-align: right">AKSI</th>
        </tr>
      </thead>
      <tbody id="customerTableBody">
        <% customers.forEach(customer => { %>
        <tr data-id="<%= customer._id %>" data-name="<%= customer.name.toLowerCase() %>">
          <td>
            <div class="table-client-info">
              <img
                src="https://ui-avatars.com/api/?name=<%= encodeURIComponent(customer.name) %>&background=random"
                class="table-client-avatar"
                alt="User"
              />
              <div>
                <span class="table-client-name"><%= customer.name %></span>
                <span class="table-client-sub" style="opacity: 0.7"
                  >ID: #CST-<%= customer._id.toString().slice(-4).toUpperCase() %></span
                >
              </div>
            </div>
          </td>
          <td>
            <div>
              <span
                style="
                  font-size: 12px;
                  font-weight: 600;
                  color: var(--text-secondary);
                "
                ><%= customer.email %></span
              >
            </div>
            <div>
              <span style="font-size: 11px; color: var(--text-secondary)"
                ><%= customer.phone %></span
              >
            </div>
          </td>
          <td>
            <span class="badge badge-layanan-blue" style="border-radius: 12px"
              >0 Pesanan</span
            >
          </td>
          <td style="font-weight: 700; color: #0d47a1">Rp 0</td>
          <td>
            <label class="toggle-switch">
              <input type="checkbox" class="status-toggle" <%= customer.isActive ? 'checked' : '' %> onchange="toggleCustomerStatus('<%= customer._id %>', this)" />
              <span class="toggle-slider"></span>
              <span class="toggle-label"><%= customer.isActive ? 'Aktif' : 'Non-Aktif' %></span>
            </label>
          </td>
          <td style="color: var(--text-secondary); font-size: 11px;">
             <%= new Date(customer.createdAt).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %>
          </td>
          <td>
            <div class="action-buttons" style="justify-content: flex-end">
              <button class="edit" onclick="openCustomerDetail('<%= JSON.stringify(customer) %>')">
                <i class="fa-regular fa-eye"></i>
              </button>
              <button class="delete" onclick="deleteCustomer('<%= customer._id %>')">
                <i class="fa-regular fa-trash-can"></i>
              </button>
            </div>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<script>
  // Update Statistics UI
  function updateStats() {
    const total = document.querySelectorAll("#customerTableBody tr").length;
    const active = document.querySelectorAll("#customerTableBody tr input.status-toggle:checked").length;
    const inactive = total - active;

    document.getElementById("statTotal").textContent = total;
    document.getElementById("statActive").textContent = active;
    document.getElementById("statInactive").textContent = inactive;
  }

  // Search logic
  const searchInput = document.getElementById("customerSearch");
  const tableRows = document.querySelectorAll("#customerTableBody tr");

  searchInput.addEventListener("input", (e) => {
    const term = e.target.value.toLowerCase();
    tableRows.forEach(row => {
      const name = row.getAttribute("data-name");
      if (name.includes(term)) {
        row.style.display = "";
      } else {
        row.style.display = "none";
      }
    });
  });

  // Toggle Status
  async function toggleCustomerStatus(id, checkbox) {
    const label = checkbox.parentElement.querySelector(".toggle-label");
    const isActive = checkbox.checked;
    
    try {
      const res = await fetch(`/api/admin/customers/${id}`, {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ isActive })
      });
      const result = await res.json();
      if (result.status === "success") {
        label.textContent = isActive ? "Aktif" : "Non-Aktif";
        updateStats(); // REALTIME UPDATE
      } else {
        checkbox.checked = !isActive;
        alert(result.message || "Gagal update status");
      }
    } catch (err) {
      checkbox.checked = !isActive;
      alert("Terjadi kesalahan");
    }
  }

  // Delete Customer
  async function deleteCustomer(id) {
    if (!confirm("Yakin ingin menghapus customer ini?")) return;

    try {
      const res = await fetch(`/api/admin/customers/${id}`, {
        method: "DELETE"
      });
      if (res.status === 204) {
        location.reload();
      } else {
        const result = await res.json();
        alert(result.message || "Gagal menghapus customer");
      }
    } catch (err) {
      alert("Terjadi kesalahan");
    }
  }

  // Customer Detail Modal
  async function openCustomerDetail(custJson) {
    const cust = JSON.parse(custJson);
    
    // Fill basic info
    document.getElementById("detailAvatar").src = `https://ui-avatars.com/api/?name=${encodeURIComponent(cust.name)}&background=0d47a1&color=fff&size=80`;
    document.getElementById("detailName").textContent = cust.name;
    document.getElementById("detailId").textContent = `#CST-${cust._id.toString().slice(-4).toUpperCase()}`;
    document.getElementById("detailEmail").innerHTML = `<i class="fa-regular fa-envelope"></i> ${cust.email}`;
    document.getElementById("detailPhone").innerHTML = `<i class="fa-solid fa-phone"></i> ${cust.phone}`;
    document.getElementById("detailJoinDate").innerHTML = `<i class="fa-regular fa-calendar"></i> Joined ${new Date(cust.createdAt).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' })}`;

    // Fetch and fill orders
    const orderTableBody = document.getElementById("orderHistoryBody");
    orderTableBody.innerHTML = '<tr><td colspan="5" style="text-align:center">Memuat riwayat pesanan...</td></tr>';
    
    try {
      const res = await fetch(`/api/admin/customers/${cust._id}/orders`);
      const result = await res.json();
      
      if (result.status === "success") {
        const orders = result.data.orders;
        let totalSpent = 0;
        
        document.getElementById("detailTotalOrders").textContent = orders.length;
        
        if (orders.length === 0) {
          orderTableBody.innerHTML = '<tr><td colspan="5" style="text-align:center">Belum ada riwayat pesanan.</td></tr>';
          document.getElementById("detailTotalSpent").textContent = "Rp 0";
        } else {
          orderTableBody.innerHTML = "";
          orders.forEach(order => {
            totalSpent += order.totalPrice;
            const services = order.items.map(item => `<span class="badge badge-layanan-gray">${item.serviceType.toUpperCase()}</span>`).join(" ");
            const statusClass = `badge-${order.status}`;
            
            const row = `
              <tr>
                <td class="cust-detail-order-id">${order.orderId || '#ORD-UNKNOWN'}</td>
                <td>${new Date(order.createdAt).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' })}</td>
                <td>${services}</td>
                <td><span class="badge badge-layanan-blue" style="text-transform: capitalize">${order.status}</span></td>
                <td>Rp ${order.totalPrice.toLocaleString('id-ID')}</td>
              </tr>
            `;
            orderTableBody.insertAdjacentHTML("beforeend", row);
          });
          document.getElementById("detailTotalSpent").textContent = `Rp ${totalSpent.toLocaleString('id-ID')}`;
        }
      }
    } catch (err) {
      orderTableBody.innerHTML = '<tr><td colspan="5" style="text-align:center; color:red">Gagal memuat pesanan.</td></tr>';
    }

    document.getElementById("customerDetailModal").classList.add("active");
  }
  
  function closeModal(e, id) {
    if (e.target.id === id) {
      document.getElementById(id).classList.remove("active");
    }
  }
  function closeModalRaw(id) {
    document.getElementById(id).classList.remove("active");
  }
</script>

<!-- Modal Detail Customer -->
<div
  class="modal-overlay"
  id="customerDetailModal"
  onclick="closeModal(event, 'customerDetailModal')"
>
  <div class="modal-content modal-content--lg">
    <!-- Header -->
    <div class="cust-detail-header">
      <img
        id="detailAvatar"
        src=""
        class="cust-detail-avatar"
        alt="Avatar"
      />
      <div class="cust-detail-info">
        <div class="cust-detail-name-row">
          <h3 id="detailName">Customer Name</h3>
          <span class="badge badge-layanan-gray" id="detailId">ID: #CST-0000</span>
        </div>
        <div class="cust-detail-meta">
          <span id="detailEmail"></span>
          <span id="detailPhone"></span>
          <span id="detailJoinDate"></span>
        </div>
      </div>
    </div>

    <!-- Stats -->
    <div class="cust-detail-stats" style="margin-top: 24px">
      <div class="cust-detail-stat">
        <span class="cust-detail-stat-label">TOTAL PESANAN</span>
        <span class="cust-detail-stat-value" id="detailTotalOrders">0</span>
      </div>
      <div class="cust-detail-stat">
        <span class="cust-detail-stat-label">TOTAL PENGELUARAN</span>
        <span class="cust-detail-stat-value" id="detailTotalSpent">Rp 0</span>
      </div>
    </div>

    <!-- Order History -->
    <h4 class="cust-detail-section-title" style="margin-top: 20px; margin-bottom: 12px; font-size: 14px; font-weight: 700; color: var(--navy-dark); text-transform: uppercase; letter-spacing: 0.5px;">Riwayat Pesanan</h4>
    <div class="admin-table-wrapper" style="overflow-y: auto; max-height: 240px; margin-bottom: 20px; border: 1px solid #f1f5f9; border-radius: 8px;">
      <table class="admin-table">
        <thead style="position: sticky; top: 0; z-index: 10; background: #fff;">
          <tr>
            <th>ORDER ID</th>
            <th>TANGGAL</th>
            <th>LAYANAN</th>
            <th>STATUS</th>
            <th>NOMINAL</th>
          </tr>
        </thead>
        <tbody id="orderHistoryBody">
          <!-- Will be filled by JS -->
        </tbody>
      </table>
    </div>

    <div class="cust-detail-footer">
      <button
        class="btn btn-primary"
        onclick="closeModalRaw('customerDetailModal')"
      >
        Tutup
      </button>
    </div>
  </div>
</div>

<%- include('../partials/dashboard-foot') %>

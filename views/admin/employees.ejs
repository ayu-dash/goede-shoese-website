<!-- ==================== MODALS ==================== -->

<!-- Modal Tambah Karyawan Baru -->
<div
  class="modal-overlay"
  id="addEmployeeModal"
  onclick="closeModal(event, 'addEmployeeModal')"
>
  <div class="modal-content" style="max-width: 380px; padding: 28px 24px">
    <h3
      class="modal-title"
      style="
        color: #0d47a1;
        margin-bottom: 20px;
        font-size: 18px;
        text-align: center;
      "
    >
      Tambah Karyawan Baru
    </h3>

    <!-- Photo Upload -->
    <div class="emp-photo-upload" style="margin-bottom: 20px">
      <div
        class="emp-photo-circle"
        style="width: 64px; height: 64px; font-size: 22px"
      >
        <i class="fa-regular fa-user"></i>
        <span
          class="emp-photo-badge"
          style="width: 20px; height: 20px; font-size: 8px"
          ><i class="fa-solid fa-camera"></i
        ></span>
      </div>
      <span class="emp-photo-label">FOTO PROFIL</span>
      <span class="emp-photo-sub">PNG / JPG / JPEG</span>
    </div>

    <form id="addEmployeeForm">
      <div class="modal-form-group" style="margin-bottom: 14px">
        <label class="modal-label">NAMA LENGKAP</label>
        <div class="modal-input-icon">
          <i class="fa-regular fa-user"></i>
          <input
            type="text"
            name="name"
            class="modal-input"
            style="padding: 10px 14px 10px 36px"
            placeholder="Contoh: Adrian Pratama"
            required
          />
        </div>
      </div>

      <div class="modal-form-group" style="margin-bottom: 14px">
        <label class="modal-label">EMAIL</label>
        <div class="modal-input-icon">
          <i class="fa-regular fa-envelope"></i>
          <input
            type="email"
            name="email"
            class="modal-input"
            style="padding: 10px 14px 10px 36px"
            placeholder="email@perusahaan.com"
            required
          />
        </div>
      </div>

      <div class="modal-form-group" style="margin-bottom: 14px">
        <label class="modal-label">NOMOR TELEPON</label>
        <div class="modal-input-icon">
          <i class="fa-solid fa-phone"></i>
          <input
            type="tel"
            name="phone"
            class="modal-input"
            style="padding: 10px 14px 10px 36px"
            placeholder="0812..."
            required
          />
        </div>
      </div>

      <div class="modal-form-group" style="margin-bottom: 24px">
        <label class="modal-label">KATA SANDI</label>
        <div class="modal-input-icon">
          <i class="fa-solid fa-lock"></i>
          <input
            type="password"
            name="password"
            class="modal-input"
            style="padding: 10px 14px 10px 36px"
            placeholder="••••••••"
            required
          />
        </div>
      </div>

      <div
        class="modal-actions"
        style="flex-direction: column; gap: 8px; margin-top: 0"
      >
        <button
          type="submit"
          class="btn btn-primary"
          style="
            width: 100%;
            background: #0d47a1;
            border-radius: 8px;
            padding: 12px;
          "
        >
          Simpan Karyawan
        </button>
        <button
          type="button"
          class="btn btn-ghost-cancel"
          style="width: 100%; font-weight: 700"
          onclick="closeModalRaw('addEmployeeModal')"
        >
          Batal
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  // Toggle label text
  document.addEventListener("DOMContentLoaded", () => {
    const toggles = document.querySelectorAll(".toggle-switch input");
    toggles.forEach((toggle) => {
      toggle.addEventListener("change", function () {
        const span = this.parentElement.querySelector(".toggle-label");
        if (this.checked) {
          span.textContent = "AKTIF";
        } else {
          span.textContent = "NON-AKTIF";
        }
      });
    });
  });

  function openModal(id) {
    document.getElementById(id).classList.add("active");
  }
  function closeModal(e, id) {
    if (e.target.id === id) {
      document.getElementById(id).classList.remove("active");
    }
  }
  function closeModalRaw(id) {
    document.getElementById(id).classList.remove("active");
  }
</script>


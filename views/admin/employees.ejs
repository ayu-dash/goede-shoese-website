<%- include('../partials/dashboard-head') %>

<div class="page-header" style="margin-bottom: 32px">
  <h1 class="page-title page-title--xl">Manajemen Karyawan</h1>
</div>

<!-- STATS CARDS -->
<div
  class="admin-stats-grid"
  style="grid-template-columns: repeat(3, 1fr); margin-bottom: 32px"
>
  <div class="admin-stat-card">
    <div class="stat-icon"><i class="fa-solid fa-user-group"></i></div>
    <div>
      <div class="stat-label">TOTAL STAFF</div>
      <div class="stat-value" id="statTotal"><%= stats.total %></div>
    </div>
  </div>
  <div class="admin-stat-card">
    <div class="stat-icon" style="color: #16a34a">
      <i class="fa-solid fa-circle-check"></i>
    </div>
    <div>
      <div class="stat-label">AKTIF</div>
      <div class="stat-value" id="statActive"><%= stats.active %></div>
    </div>
  </div>
  <div class="admin-stat-card">
    <div class="stat-icon" style="color: #ef4444">
      <i class="fa-solid fa-circle-xmark"></i>
    </div>
    <div>
      <div class="stat-label">TIDAK AKTIF</div>
      <div class="stat-value" id="statInactive"><%= stats.inactive %></div>
    </div>
  </div>
</div>

<!-- EMPLOYEE TABLE -->
<div class="admin-panel">
  <div class="filter-bar">
    <div class="search-wrapper">
      <i class="fa-solid fa-magnifying-glass"></i>
      <input
        type="text"
        id="employeeSearch"
        class="search-input"
        placeholder="Filter berdasarkan nama..."
      />
    </div>
    <button class="btn btn-primary" onclick="openModal('addEmployeeModal')">
      + Tambah Karyawan
    </button>
  </div>

  <div class="admin-table-wrapper" style="overflow-x: auto">
    <table class="admin-table">
      <thead>
        <tr>
          <th>NAMA LENGKAP</th>
          <th>KONTAK</th>
          <th>STATUS</th>
          <th style="text-align: right">AKSI</th>
        </tr>
      </thead>
      <tbody id="employeeTableBody">
        <% employees.forEach(employee => { %>
        <tr data-id="<%= employee._id %>" data-name="<%= employee.name.toLowerCase() %>">
          <td>
            <div class="table-client-info">
              <img
                src="https://ui-avatars.com/api/?name=<%= encodeURIComponent(employee.name) %>&background=random"
                class="table-client-avatar"
                alt="User"
              />
              <div>
                <span class="table-client-name"><%= employee.name %></span>
              </div>
            </div>
          </td>
          <td>
            <div>
              <span
                style="
                  font-size: 12px;
                  font-weight: 600;
                  color: var(--text-secondary);
                "
                ><%= employee.email %></span
              >
            </div>
            <div>
              <span style="font-size: 11px; color: var(--text-secondary)"
                ><%= employee.phone %></span
              >
            </div>
          </td>
          <td>
            <label class="toggle-switch">
              <input type="checkbox" class="status-toggle" <%= employee.isActive ? 'checked' : '' %> onchange="toggleEmployeeStatus('<%= employee._id %>', this)" />
              <span class="toggle-slider"></span>
              <span class="toggle-label"><%= employee.isActive ? 'AKTIF' : 'NON-AKTIF' %></span>
            </label>
          </td>
          <td>
            <div class="action-buttons" style="justify-content: flex-end">
              <button class="edit" onclick="openEditModal('<%= JSON.stringify(employee) %>')">
                <i class="fa-regular fa-pen-to-square"></i>
              </button>
              <button class="delete" onclick="deleteEmployee('<%= employee._id %>')">
                <i class="fa-regular fa-trash-can"></i>
              </button>
            </div>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<!-- ==================== MODALS ==================== -->

<!-- Modal Tambah Karyawan Baru -->
<div
  class="modal-overlay"
  id="addEmployeeModal"
  onclick="closeModal(event, 'addEmployeeModal')"
>
  <div class="modal-content" style="max-width: 380px; padding: 28px 24px">
    <h3
      class="modal-title"
      style="
        color: #0d47a1;
        margin-bottom: 20px;
        font-size: 18px;
        text-align: center;
      "
    >
      Tambah Karyawan Baru
    </h3>

    <form id="addEmployeeForm">
      <div class="modal-form-group" style="margin-bottom: 14px">
        <label class="modal-label">NAMA LENGKAP</label>
        <div class="modal-input-icon">
          <i class="fa-regular fa-user"></i>
          <input
            type="text"
            name="name"
            class="modal-input"
            style="padding: 10px 14px 10px 36px"
            placeholder="Contoh: Adrian Pratama"
            required
          />
        </div>
      </div>

      <div class="modal-form-group" style="margin-bottom: 14px">
        <label class="modal-label">EMAIL</label>
        <div class="modal-input-icon">
          <i class="fa-regular fa-envelope"></i>
          <input
            type="email"
            name="email"
            class="modal-input"
            style="padding: 10px 14px 10px 36px"
            placeholder="email@perusahaan.com"
            required
          />
        </div>
      </div>

      <div class="modal-form-group" style="margin-bottom: 14px">
        <label class="modal-label">NOMOR TELEPON</label>
        <div class="modal-input-icon">
          <i class="fa-solid fa-phone"></i>
          <input
            type="tel"
            name="phone"
            class="modal-input"
            style="padding: 10px 14px 10px 36px"
            placeholder="0812..."
            required
          />
        </div>
      </div>

      <div class="modal-form-group" style="margin-bottom: 24px">
        <label class="modal-label">KATA SANDI</label>
        <div class="modal-input-icon">
          <i class="fa-solid fa-lock"></i>
          <input
            type="password"
            name="password"
            class="modal-input"
            style="padding: 10px 14px 10px 36px"
            placeholder="••••••••"
            required
          />
        </div>
      </div>

      <div
        class="modal-actions"
        style="flex-direction: column; gap: 8px; margin-top: 0"
      >
        <button
          type="submit"
          class="btn btn-primary"
          style="
            width: 100%;
            background: #0d47a1;
            border-radius: 8px;
            padding: 12px;
          "
        >
          Simpan Karyawan
        </button>
        <button
          type="button"
          class="btn btn-ghost-cancel"
          style="width: 100%; font-weight: 700"
          onclick="closeModalRaw('addEmployeeModal')"
        >
          Batal
        </button>
      </div>
    </form>
  </div>
</div>

<!-- Modal Edit Karyawan -->
<div
  class="modal-overlay"
  id="editEmployeeModal"
  onclick="closeModal(event, 'editEmployeeModal')"
>
  <div class="modal-content" style="max-width: 380px; padding: 28px 24px">
    <h3
      class="modal-title"
      style="
        color: #0d47a1;
        margin-bottom: 20px;
        font-size: 18px;
        text-align: center;
      "
    >
      Edit Data Karyawan
    </h3>

    <form id="editEmployeeForm">
      <input type="hidden" name="id" id="editEmployeeId" />
      <div class="modal-form-group" style="margin-bottom: 14px">
        <label class="modal-label">NAMA LENGKAP</label>
        <div class="modal-input-icon">
          <i class="fa-regular fa-user"></i>
          <input
            type="text"
            name="name"
            id="editEmployeeName"
            class="modal-input"
            style="padding: 10px 14px 10px 36px"
            placeholder="Contoh: Adrian Pratama"
            required
          />
        </div>
      </div>

      <div class="modal-form-group" style="margin-bottom: 14px">
        <label class="modal-label">EMAIL</label>
        <div class="modal-input-icon">
          <i class="fa-regular fa-envelope"></i>
          <input
            type="email"
            name="email"
            id="editEmployeeEmail"
            class="modal-input"
            style="padding: 10px 14px 10px 36px"
            placeholder="email@perusahaan.com"
            required
          />
        </div>
      </div>

      <div class="modal-form-group" style="margin-bottom: 14px">
        <label class="modal-label">NOMOR TELEPON</label>
        <div class="modal-input-icon">
          <i class="fa-solid fa-phone"></i>
          <input
            type="tel"
            name="phone"
            id="editEmployeePhone"
            class="modal-input"
            style="padding: 10px 14px 10px 36px"
            placeholder="0812..."
            required
          />
        </div>
      </div>

      <div class="modal-form-group" style="margin-bottom: 24px">
        <label class="modal-label">KATA SANDI BARU (OPSIONAL)</label>
        <div class="modal-input-icon">
          <i class="fa-solid fa-lock"></i>
          <input
            type="password"
            name="password"
            class="modal-input"
            style="padding: 10px 14px 10px 36px"
            placeholder="Isi jika ingin diubah"
          />
        </div>
      </div>

      <div
        class="modal-actions"
        style="flex-direction: column; gap: 8px; margin-top: 0"
      >
        <button
          type="submit"
          class="btn btn-primary"
          style="
            width: 100%;
            background: #0d47a1;
            border-radius: 8px;
            padding: 12px;
          "
        >
          Update Karyawan
        </button>
        <button
          type="button"
          class="btn btn-ghost-cancel"
          style="width: 100%; font-weight: 700"
          onclick="closeModalRaw('editEmployeeModal')"
        >
          Batal
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  function openModal(id) {
    document.getElementById(id).classList.add("active");
  }
  function closeModal(e, id) {
    if (e.target.id === id) {
      document.getElementById(id).classList.remove("active");
    }
  }
  function closeModalRaw(id) {
    document.getElementById(id).classList.remove("active");
  }

  // Update Statistics UI
  function updateStats() {
    const total = document.querySelectorAll("#employeeTableBody tr").length;
    const active = document.querySelectorAll("#employeeTableBody tr input.status-toggle:checked").length;
    const inactive = total - active;

    document.getElementById("statTotal").textContent = total;
    document.getElementById("statActive").textContent = active;
    document.getElementById("statInactive").textContent = inactive;
  }

  // Search logic
  const searchInput = document.getElementById("employeeSearch");
  const tableRows = document.querySelectorAll("#employeeTableBody tr");

  searchInput.addEventListener("input", (e) => {
    const term = e.target.value.toLowerCase();
    tableRows.forEach(row => {
      const name = row.getAttribute("data-name");
      if (name.includes(term)) {
        row.style.display = "";
      } else {
        row.style.display = "none";
      }
    });
  });

  // Create Employee
  const addForm = document.getElementById("addEmployeeForm");
  addForm.addEventListener("submit", async (e) => {
    e.preventDefault();
    const formData = new FormData(addForm);
    const data = Object.fromEntries(formData.entries());

    try {
      const res = await fetch("/api/admin/staff", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data)
      });
      const result = await res.json();
      if (result.status === "success") {
        location.reload();
      } else {
        alert(result.message || "Gagal menambah karyawan");
      }
    } catch (err) {
      alert("Terjadi kesalahan");
    }
  });

  // Toggle Status
  async function toggleEmployeeStatus(id, checkbox) {
    const label = checkbox.parentElement.querySelector(".toggle-label");
    const isActive = checkbox.checked;
    
    try {
      const res = await fetch(`/api/admin/staff/${id}`, {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ isActive })
      });
      const result = await res.json();
      if (result.status === "success") {
        label.textContent = isActive ? "AKTIF" : "NON-AKTIF";
        updateStats(); // REALTIME UPDATE
      } else {
        checkbox.checked = !isActive;
        alert(result.message || "Gagal update status");
      }
    } catch (err) {
      checkbox.checked = !isActive;
      alert("Terjadi kesalahan");
    }
  }

  // Delete Employee
  async function deleteEmployee(id) {
    if (!confirm("Yakin ingin menghapus karyawan ini?")) return;

    try {
      const res = await fetch(`/api/admin/staff/${id}`, {
        method: "DELETE"
      });
      if (res.status === 204) {
        location.reload();
      } else {
        const result = await res.json();
        alert(result.message || "Gagal menghapus karyawan");
      }
    } catch (err) {
      alert("Terjadi kesalahan");
    }
  }

  // Edit Employee
  function openEditModal(empJson) {
    const emp = JSON.parse(empJson);
    document.getElementById("editEmployeeId").value = emp._id;
    document.getElementById("editEmployeeName").value = emp.name;
    document.getElementById("editEmployeeEmail").value = emp.email;
    document.getElementById("editEmployeePhone").value = emp.phone;
    openModal("editEmployeeModal");
  }

  const editForm = document.getElementById("editEmployeeForm");
  editForm.addEventListener("submit", async (e) => {
    e.preventDefault();
    const id = document.getElementById("editEmployeeId").value;
    const formData = new FormData(editForm);
    const data = Object.fromEntries(formData.entries());

    try {
      const res = await fetch(`/api/admin/staff/${id}`, {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data)
      });
      const result = await res.json();
      if (result.status === "success") {
        location.reload();
      } else {
        alert(result.message || "Gagal update karyawan");
      }
    } catch (err) {
      alert("Terjadi kesalahan");
    }
  });
</script>

<%- include('../partials/dashboard-foot') %>

<%- include('../partials/dashboard-head') %>

  <!-- ORDER DETAIL HEADER -->
  <div class="page-header page-header--detail">
    <div>
      <h1 class="page-title">Order #<%= order.orderId %>
      </h1>
      <p class="page-subtitle">
        <i class="fa-regular fa-clock"></i> Terakhir diperbarui: <%= new
          Date(order.updatedAt).toLocaleDateString('id-ID', { day: 'numeric' , month: 'short' , year: 'numeric' }) %>
      </p>
    </div>
    <% var statusClass="process" ; if(order.status==='completed' ) statusClass="done" ; if(order.status==='cancelled' )
      statusClass="cancel" ; %>
      <span class="status-badge status-badge--<%= statusClass %>">
        <%= (order.status || 'PENDING' ).toUpperCase() %>
      </span>
  </div>

  <div class="detail-layout">
    <!-- LEFT: ORDER ITEMS -->
    <div class="detail-items-col">
      <% order.items.forEach(function(item, index) { %>
        <div class="detail-item-card">
          <div class="detail-item-top">
            <% var detailShoePhoto=null; if (order.statusHistory) { for (var i=0; i < order.statusHistory.length; i++) {
              if (order.statusHistory[i].status==='validating-in' && order.statusHistory[i].photos &&
              order.statusHistory[i].photos.length> 0) {
              detailShoePhoto = order.statusHistory[i].photos[0];
              break;
              }
              }
              }
              %>
              <img src="<%= detailShoePhoto || '/images/hero-shoe.png' %>" alt="<%= item.shoeName %>"
                class="detail-item-img" />
              <div class="detail-item-info">
                <h4 class="detail-item-name">
                  <%= item.shoeName %>
                </h4>
                <span class="detail-item-service">
                  <%= item.serviceType %>
                    <%= (item.addons && item.addons.length> 0) ? '+ ' + item.addons.join(', ') : '' %>
                </span>
              </div>

              <% var steps=[ { key: 'pending' , label: 'Submit' , icon: 'fa-file-invoice' }, { key: 'pickup' ,
                label: 'Penjemputan' , icon: 'fa-truck-pickup' }, { key: 'validating-in' , label: 'Cek Kondisi' ,
                icon: 'fa-clipboard-check' }, { key: 'in-progress' , label: 'Pencucian' , icon: 'fa-soap' }, {
                key: 'quality-check' , label: 'Cek Hasil' , icon: 'fa-magnifying-glass' }, { key: 'delivery' ,
                label: 'Pengantaran' , icon: 'fa-truck' }, { key: 'completed' , label: 'Selesai' ,
                icon: 'fa-check-circle' } ]; var effectiveStatus=order.status; var currentIdx=-1; for (var j=0; j <
                steps.length; j++) { if (steps[j].key===effectiveStatus) { currentIdx=j; break; } } var pct=currentIdx>=
                0 ? Math.round((currentIdx / (steps.length - 1)) * 100) : 0;
                %>
                <div class="detail-item-pct">
                  <span class="detail-pct-num">
                    <%= pct %>%
                  </span>
                  <span class="detail-pct-label">COMPLETED</span>
                </div>
          </div>

          <div class="timeline" style="margin-top: 20px; padding-top: 20px; border-top: 1px dashed var(--gray-light);">
            <% steps.forEach(function(step, index) { %>
              <% var stepStatusClass="" ; if (order.status==='cancelled' ) { stepStatusClass="cancelled" ; } else if
                (index < currentIdx || order.status==='completed' ) { stepStatusClass="completed" ; } else if
                (index===currentIdx) { stepStatusClass="active" ; } %>
                <div class="timeline-step <%= stepStatusClass %>" style="min-width: 60px;">
                  <div class="timeline-dot"><i class="fa-solid <%= step.icon %>"></i></div>
                  <span class="timeline-label" style="font-size: 8.5px;">
                    <%= step.label %>
                  </span>
                </div>

                <% if (index < steps.length - 1) { %>
                  <% var lineStatusClass="" ; if (order.status !=='cancelled' && (index < currentIdx ||
                    order.status==='completed' )) { lineStatusClass="completed" ; } %>
                    <div class="timeline-line <%= lineStatusClass %>"></div>
                    <% } %>
                      <% }); %>
          </div>
        </div>
        <% }); %>

          <!-- Dokumentasi Hasil & Kondisi -->
          <% var validatingInEntry=null; var qualityCheckEntry=null; if (order.statusHistory) { for (var k=0; k <
            order.statusHistory.length; k++) { if (order.statusHistory[k].status==='validating-in' )
            validatingInEntry=order.statusHistory[k]; if (order.statusHistory[k].status==='quality-check' )
            qualityCheckEntry=order.statusHistory[k]; } } %>

            <% if (validatingInEntry || qualityCheckEntry) { %>
              <div class="detail-item-card" style="margin-top: 20px;">
                <h5
                  style="font-size: 14px; font-weight: 700; color: var(--navy-dark); margin-bottom: 20px; display: flex; align-items: center; gap: 10px;">
                  <i class="fa-solid fa-camera-retro" style="color: var(--navy); font-size: 18px;"></i> DOKUMENTASI &
                  CATATAN PETUGAS
                </h5>

                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px;">
                  <% if (validatingInEntry) { %>
                    <div style="background: #f8fafc; padding: 20px; border-radius: 12px; border: 1px solid #e2e8f0;">
                      <div
                        style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
                        <span
                          style="font-size: 11px; font-weight: 800; color: var(--navy); text-transform: uppercase;">Kondisi
                          Awal</span>
                        <span style="font-size: 10px; color: var(--text-secondary);">
                          <%= new Date(validatingInEntry.updatedAt).toLocaleDateString('id-ID') %>
                        </span>
                      </div>
                      <% if (validatingInEntry.note) { %>
                        <div
                          style="font-size: 13px; margin-bottom: 12px; padding: 10px; background: #fff; border-radius: 6px; border-left: 4px solid var(--navy);">
                          <%= validatingInEntry.note %>
                        </div>
                        <% } %>
                          <% if (validatingInEntry.photos && validatingInEntry.photos.length> 0) { %>
                            <div style="display: flex; gap: 8px; overflow-x: auto;">
                              <% validatingInEntry.photos.forEach(function(photo) { %>
                                <img src="<%= photo %>"
                                  style="width: 80px; height: 80px; object-fit: cover; border-radius: 6px; cursor: pointer;"
                                  onclick="window.open(this.src)">
                                <% }); %>
                            </div>
                            <% } %>
                    </div>
                    <% } %>

                      <% if (qualityCheckEntry) { %>
                        <div
                          style="background: #f0fdf4; padding: 20px; border-radius: 12px; border: 1px solid #dcfce7;">
                          <div
                            style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
                            <span
                              style="font-size: 11px; font-weight: 800; color: #166534; text-transform: uppercase;">Hasil
                              Cuci</span>
                            <span style="font-size: 10px; color: #166534;">
                              <%= new Date(qualityCheckEntry.updatedAt).toLocaleDateString('id-ID') %>
                            </span>
                          </div>
                          <% if (qualityCheckEntry.note) { %>
                            <div
                              style="font-size: 13px; margin-bottom: 12px; padding: 10px; background: #fff; border-radius: 6px; border-left: 4px solid #22c55e;">
                              <%= qualityCheckEntry.note %>
                            </div>
                            <% } %>
                              <% if (qualityCheckEntry.photos && qualityCheckEntry.photos.length> 0) { %>
                                <div style="display: flex; gap: 8px; overflow-x: auto;">
                                  <% qualityCheckEntry.photos.forEach(function(photo) { %>
                                    <img src="<%= photo %>"
                                      style="width: 80px; height: 80px; object-fit: cover; border-radius: 6px; cursor: pointer;"
                                      onclick="window.open(this.src)">
                                    <% }); %>
                                </div>
                                <% } %>
                        </div>
                        <% } %>
                </div>
              </div>
              <% } %>
    </div>

    <!-- RIGHT: LOGISTICS & SUMMARY -->
    <div class="detail-sidebar-col">
      <div class="detail-logistics-card">
        <h4 class="detail-card-title"><i class="fa-solid fa-truck"></i> Logistics Details</h4>
        <div class="logistics-info-item">
          <span class="logistics-info-label">PICKUP: <%= (order.logistics.pickupMethod || '' ).toUpperCase() %></span>
          <span class="logistics-info-value">
            <% if(order.logistics.pickupMethod==='pickup' ) { %>
              <% var fbP=(order.user && order.user.addresses && order.user.addresses.length> 0) ?
                order.user.addresses[0].fullAddress : 'Belum ditentukan'; %>
                <%= order.logistics.pickupAddress || fbP %>
                  <% } else { %>
                    <%= settings.storeInfo.address %> (Drop-off)
                      <% } %>
          </span>
        </div>
        <div class="logistics-info-item">
          <span class="logistics-info-label">DELIVERY: <%= (order.logistics.deliveryMethod || '' ).toUpperCase() %>
          </span>
          <span class="logistics-info-value">
            <% if(order.logistics.deliveryMethod==='delivery' ) { %>
              <% var fbD=(order.user && order.user.addresses && order.user.addresses.length> 0) ?
                order.user.addresses[0].fullAddress : 'Belum ditentukan'; %>
                <%= order.logistics.deliveryAddress || fbD %>
                  <% } else { %>
                    <%= settings.storeInfo.address %> (Ambil di Gerai)
                      <% } %>
          </span>
        </div>
      </div>

      <!-- Ringkasan Pesanan -->
      <div class="order-summary-card">
        <h4 class="order-summary-title">Ringkasan Pesanan</h4>
        <% var SERVICE_PRICES={ "Deep Clean (Regular)" : 40000, "Fast Clean" : 25000, "Deep Clean Express" :
          60000, "Premium Repaint" : 150000 }; var ADDON_PRICES={ "Unyellowing" : 50000, "Glue & Repress" :
          60000, "Leather Polish" : 30000, "Deodorizer" : 15000 }; %>

          <% order.items.forEach(function(item) { %>
            <div class="order-summary-item-wrapper"
              style="margin-bottom: 12px; border-bottom: 1px solid #eee; padding-bottom: 8px;">
              <div class="order-summary-item" style="display: flex; justify-content: space-between;">
                <div>
                  <span style="display: block; font-weight: 700;">
                    <%= item.shoeName %>
                  </span>
                  <span style="font-size: 11px; color: #666;">
                    <%= (item.serviceType || '' ).toUpperCase() %>
                  </span>
                </div>
                <span style="font-weight: 700;">Rp <%= (SERVICE_PRICES[item.serviceType] ||
                    40000).toLocaleString('id-ID') %></span>
              </div>
              <% if (item.addons && item.addons.length> 0) { %>
                <% item.addons.forEach(function(addon) { %>
                  <div
                    style="display: flex; justify-content: space-between; font-size: 11px; color: #666; margin-top: 4px; padding-left: 10px;">
                    <span>+ <%= addon %></span>
                    <span>Rp <%= (ADDON_PRICES[addon] || 0).toLocaleString('id-ID') %></span>
                  </div>
                  <% }); %>
                    <% } %>
            </div>
            <% }); %>

              <% if (order.logistics.pickupFee> 0) { %>
                <div class="order-summary-row"
                  style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                  <span>Biaya Penjemputan</span>
                  <span>Rp <%= (order.logistics.pickupFee || 0).toLocaleString('id-ID') %></span>
                </div>
                <% } %>

                  <% if (order.logistics.deliveryFee> 0) { %>
                    <div class="order-summary-row"
                      style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                      <span>Biaya Pengantaran</span>
                      <span>Rp <%= (order.logistics.deliveryFee || 0).toLocaleString('id-ID') %></span>
                    </div>
                    <% } %>

                      <div class="order-summary-row order-summary-total"
                        style="display: flex; justify-content: space-between; font-weight: 800; font-size: 1.1rem; color: var(--navy);">
                        <span>TOTAL</span>
                        <span>Rp <%= order.totalPrice.toLocaleString('id-ID') %></span>
                      </div>
      </div>
    </div>
  </div>

  <%- include('../partials/dashboard-foot') %>
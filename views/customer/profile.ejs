<%- include('../partials/dashboard-head') %>

<div class="page-header page-header--profile">
  <h1 class="page-title page-title--xl">PROFIL CUSTOMER</h1>
</div>

<!-- PROFILE CARD -->
<div class="profile-card" id="profileCard">
  <div class="profile-card-header">
    <div class="profile-info-main">
      <img src="https://ui-avatars.com/api/?name=<%= encodeURIComponent(user.name) %>&background=0D8ABC&color=fff&size=150" class="profile-avatar" alt="Avatar">
      <div class="profile-name-block">
        <h3><%= user.name %></h3>
        <span class="profile-joined">Bergabung sejak <%= new Date(user.createdAt).toLocaleDateString('id-ID', { month: 'short', year: 'numeric' }) %></span>
      </div>
    </div>
    <button class="btn-edit-profile" onclick="toggleEditMode(true)">
      <i class="fa-solid fa-pen"></i> EDIT PROFILE
    </button>
  </div>

  <div class="profile-fields-grid">
    <div>
      <span class="profile-field-label">FULL NAME</span>
      <span class="profile-field-value"><%= user.name %></span>
      <input type="text" class="profile-field-input" id="edit-name" value="<%= user.name %>">
    </div>
    <div>
      <span class="profile-field-label">EMAIL ADDRESS</span>
      <span class="profile-field-value"><%= user.email %></span>
      <input type="email" class="profile-field-input" id="edit-email" value="<%= user.email %>">
    </div>
    <div>
      <span class="profile-field-label">PHONE NUMBER</span>
      <span class="profile-field-value"><%= user.phone %></span>
      <input type="tel" class="profile-field-input" id="edit-phone" value="<%= user.phone %>">
    </div>
  </div>

  <div class="profile-edit-actions">
    <button class="btn btn-white btn-sm btn-ghost-cancel" onclick="toggleEditMode(false)">BATAL</button>
    <button class="btn btn-primary btn-sm" onclick="saveProfile()">SIMPAN PERUBAHAN</button>
  </div>
</div>

<!-- STATS -->
<div class="profile-stats-grid">
  <div class="profile-stat-box">
    <div class="stat-box-icon"><i class="fa-solid fa-shoe-prints"></i></div>
    <div>
      <span class="stat-box-val"><%= String(userStats.totalOrders).padStart(2, '0') %></span>
      <span class="stat-box-title">TOTAL PESANAN</span>
    </div>
  </div>
  <div class="profile-stat-box">
    <div class="stat-box-icon brown"><i class="fa-regular fa-clipboard"></i></div>
    <div>
      <span class="stat-box-val"><%= String(userStats.activeOrders).padStart(2, '0') %></span>
      <span class="stat-box-title">PESANAN AKTIF</span>
    </div>
  </div>
  <div class="profile-stat-box">
    <div class="stat-box-icon gray"><i class="fa-solid fa-money-bill-wave"></i></div>
    <div>
      <span class="stat-box-val">Rp <%= (userStats.totalSpent / 1000).toLocaleString('id-ID', { maximumFractionDigits: 1 }) %>k</span>
      <span class="stat-box-title">TOTAL PENGELUARAN</span>
    </div>
  </div>
</div>

<!-- ADDRESSES -->
<div class="address-header">
  <h2 class="address-title">ALAMAT TERSIMPAN</h2>
  <button class="btn-add-address" onclick="openModal('addAddressModal')">
    <i class="fa-solid fa-circle-plus"></i> Tambah Alamat Baru
  </button>
</div>

<div class="address-grid">
  <% if (user.addresses && user.addresses.length > 0) { %>
    <% user.addresses.forEach(addr => { %>
      <div class="address-card">
        <div class="address-card-actions">
          <button data-addr='<%= JSON.stringify(addr) %>' onclick="prepareEditAddress(JSON.parse(this.getAttribute('data-addr')))">
            <i class="fa-solid fa-pen"></i>
          </button>
          <button><i class="fa-solid fa-trash-can"></i></button>
        </div>
        <span class="address-badge <%= addr.label.toUpperCase() === 'KANTOR' ? 'gray' : '' %>"><%= addr.label.toUpperCase() %></span>
        <h4 class="address-recipient text-truncate"><%= addr.recipientName %></h4>
        <p class="address-detail"><%= addr.fullAddress %></p>
        <p class="address-phone"><i class="fa-solid fa-phone"></i> <%= user.phone %></p>
      </div>
    <% }) %>
  <% } else { %>
    <p class="text-muted">Belum ada alamat tersimpan.</p>
  <% } %>
</div>

<!-- ==================== MODALS ==================== -->

<!-- Modal Add Address -->
<div class="modal-overlay" id="addAddressModal" onclick="closeModal(event, 'addAddressModal')">
  <div class="modal-content">
    <h3 class="modal-title">Tambah Alamat Baru</h3>
    <form onsubmit="event.preventDefault();">
      <div class="modal-form-grid">
        <div class="modal-form-group">
          <label class="modal-label">NAMA ALAMAT</label>
          <input type="text" class="modal-input" id="addr-label" placeholder="Contoh: Rumah, Kantor, Ap...">
        </div>
        <div class="modal-form-group">
          <label class="modal-label">NAMA PENERIMA</label>
          <input type="text" class="modal-input" id="addr-recipient" placeholder="Masukkan nama lengkap">
        </div>
        <div class="modal-form-group full">
          <label class="modal-label">NOMOR TELEPON (OPSIONAL)</label>
          <input type="tel" class="modal-input" id="addr-phone" placeholder="+62">
        </div>
        <div class="modal-form-group full">
          <label class="modal-label">ALAMAT LENGKAP</label>
          <textarea class="modal-input" id="addr-full" placeholder="Tuliskan alamat detail (Nama jalan, No. rumah, RT/RW, Kecamatan)"></textarea>
        </div>
        <div class="modal-form-group full">
          <label class="modal-label">CATATAN ALAMAT (OPSIONAL)</label>
          <textarea class="modal-input" id="addr-notes" placeholder="Warna pagar, dekat pos satpam, atau instruksi khusus lainnya..."></textarea>
        </div>
      </div>
      <div class="modal-actions">
        <button type="button" class="btn btn-primary" onclick="addAddress()">Simpan Alamat</button>
        <button type="button" class="btn btn-white btn-ghost-cancel" onclick="closeModalRaw('addAddressModal')">Batal</button>
      </div>
    </form>
  </div>
</div>

<!-- Modal Edit Address -->
<div class="modal-overlay" id="editAddressModal" onclick="closeModal(event, 'editAddressModal')">
  <div class="modal-content">
    <h3 class="modal-title">Edit Alamat</h3>
    <form onsubmit="event.preventDefault();">
      <div class="modal-form-grid">
        <div class="modal-form-group">
          <label class="modal-label">NAMA ALAMAT</label>
          <input type="text" class="modal-input" id="edit-addr-label">
        </div>
        <div class="modal-form-group">
          <label class="modal-label">NAMA PENERIMA</label>
          <input type="text" class="modal-input" id="edit-addr-recipient">
        </div>
        <div class="modal-form-group full">
          <label class="modal-label">NOMOR TELEPON (OPSIONAL)</label>
          <input type="tel" class="modal-input" id="edit-addr-phone">
        </div>
        <div class="modal-form-group full">
          <label class="modal-label">ALAMAT LENGKAP</label>
          <textarea class="modal-input" id="edit-addr-full"></textarea>
        </div>
        <div class="modal-form-group full">
          <label class="modal-label">CATATAN ALAMAT (OPSIONAL)</label>
          <textarea class="modal-input" id="edit-addr-notes"></textarea>
        </div>
      </div>
      <div class="modal-actions">
        <button type="button" class="btn btn-primary" onclick="saveEditAddress()">Simpan Perubahan</button>
        <button type="button" class="btn btn-white btn-ghost-cancel" onclick="closeModalRaw('editAddressModal')">Batal</button>
      </div>
    </form>
  </div>
</div>

<script>
  let currentEditingAddressId = null;

  function toggleEditMode(isEditing) {
    const card = document.getElementById('profileCard');
    if(isEditing) {
      card.classList.add('is-editing');
    } else {
      card.classList.remove('is-editing');
    }
  }

  async function saveProfile() {
    const name = document.getElementById('edit-name').value;
    const email = document.getElementById('edit-email').value;
    const phone = document.getElementById('edit-phone').value;
    
    const btn = document.querySelector('.profile-edit-actions .btn-primary');
    const originalText = btn.innerText;
    btn.innerText = "MENYIMPAN...";
    btn.disabled = true;

    try {
      const res = await fetch('/api/users/updateMe', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, email, phone })
      });

      const data = await res.json();
      if (data.status === 'success') {
        alert('Profil berhasil diperbarui!');
        location.reload();
      } else {
        alert('Gagal memperbarui profil: ' + data.message);
      }
    } catch (err) {
      alert('Terjadi kesalahan koneksi.');
    } finally {
      btn.innerText = originalText;
      btn.disabled = false;
    }
  }

  async function addAddress() {
    const label = document.getElementById('addr-label').value;
    const recipientName = document.getElementById('addr-recipient').value;
    const fullAddress = document.getElementById('addr-full').value;
    const notes = document.getElementById('addr-notes').value;

    if (!label || !recipientName || !fullAddress) {
      alert('Mohon isi label, nama penerima, dan alamat lengkap.');
      return;
    }

    const btn = document.querySelector('#addAddressModal .btn-primary');
    const originalText = btn.innerText;
    btn.innerText = "MENYIMPAN...";
    btn.disabled = true;

    try {
      const res = await fetch('/api/users/addAddress', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ label, recipientName, fullAddress, notes })
      });

      const data = await res.json();
      if (data.status === 'success') {
        alert('Alamat berhasil ditambahkan!');
        location.reload();
      } else {
        alert('Gagal menambahkan alamat: ' + data.message);
      }
    } catch (err) {
      alert('Terjadi kesalahan koneksi.');
    } finally {
      btn.innerText = originalText;
      btn.disabled = false;
    }
  }

  function prepareEditAddress(addr) {
    currentEditingAddressId = addr._id;
    document.getElementById('edit-addr-label').value = addr.label;
    document.getElementById('edit-addr-recipient').value = addr.recipientName;
    document.getElementById('edit-addr-full').value = addr.fullAddress;
    document.getElementById('edit-addr-notes').value = addr.notes || '';
    openModal('editAddressModal');
  }

  async function saveEditAddress() {
    const label = document.getElementById('edit-addr-label').value;
    const recipientName = document.getElementById('edit-addr-recipient').value;
    const fullAddress = document.getElementById('edit-addr-full').value;
    const notes = document.getElementById('edit-addr-notes').value;

    if (!label || !recipientName || !fullAddress) {
      alert('Mohon isi label, nama penerima, dan alamat lengkap.');
      return;
    }

    const btn = document.querySelector('#editAddressModal .btn-primary');
    const originalText = btn.innerText;
    btn.innerText = "MENYIMPAN...";
    btn.disabled = true;

    try {
      const res = await fetch(`/api/users/updateAddress/${currentEditingAddressId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ label, recipientName, fullAddress, notes })
      });

      const data = await res.json();
      if (data.status === 'success') {
        alert('Alamat berhasil diperbarui!');
        location.reload();
      } else {
        alert('Gagal memperbarui alamat: ' + data.message);
      }
    } catch (err) {
      alert('Terjadi kesalahan koneksi.');
    } finally {
      btn.innerText = originalText;
      btn.disabled = false;
    }
  }

  function openModal(id) {
    document.getElementById(id).classList.add('active');
  }

  function closeModal(e, id) {
    if (e.target.id === id) {
      document.getElementById(id).classList.remove('active');
    }
  }

  function closeModalRaw(id) {
    document.getElementById(id).classList.remove('active');
  }
</script>

<%- include('../partials/dashboard-foot') %>

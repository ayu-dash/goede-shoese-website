<%- include('../partials/dashboard-head') %>

<!-- PAGE HEADER -->
<div class="page-header">
  <h1 class="page-title page-title--xl">PESANAN SAYA</h1>
</div>

<!-- FILTER TABS -->
<div class="order-tabs">
  <button class="order-tab active" data-filter="all">Semua</button>
  <button class="order-tab" data-filter="proses">Dalam Proses</button>
  <button class="order-tab" data-filter="selesai">Selesai</button>
  <button class="order-tab" data-filter="batal">Dibatalkan</button>
</div>

<!-- PESANAN AKTIF -->
<div class="orders-section" id="active-orders-section">
  <div class="orders-section-header">
    <h3 class="dash-subtitle dash-subtitle--upper">PESANAN AKTIF</h3>
    <% const activeOrders = orders.filter(function(o) { return !["completed", "cancelled"].includes(o.status) }) %>
    <span class="orders-badge"><%= activeOrders.length %> BERLANGSUNG</span>
  </div>

  <% if (activeOrders.length === 0) { %>
    <div class="empty-state">
      <p>Tidak ada pesanan aktif saat ini.</p>
    </div>
  <% } else { %>
    <% activeOrders.forEach(function(order) { %>
      <div class="active-order-card" data-order-status="proses">
        <div class="active-order-img">
          <% 
            let shoePhoto = '/images/hero-shoe.png';
            if (order.items && order.items.length > 0) {
              const item = order.items[0];
              if (item.photosAfter && item.photosAfter.length > 0) {
                shoePhoto = item.photosAfter[0];
              } else if (item.photosBefore && item.photosBefore.length > 0) {
                shoePhoto = item.photosBefore[0];
              } else {
                const qcPhoto = (order.statusHistory.find(h => h.status === 'quality-check') || {}).photos;
                const valPhoto = (order.statusHistory.find(h => h.status === 'validating-in') || {}).photos;
                if (qcPhoto && qcPhoto.length > 0) {
                  shoePhoto = qcPhoto[0];
                } else if (valPhoto && valPhoto.length > 0) {
                  shoePhoto = valPhoto[0];
                }
              }
            }
          %>
          <img src="<%= shoePhoto %>" alt="Sepatu" />
        </div>
        <div class="active-order-content">
          <div class="active-order-top">
            <div>
              <span class="active-order-id">#<%= order.orderId %></span>
              <h4 class="active-order-name">
                <%= order.items[0].shoeName %> 
                <%= order.items.length > 1 ? `+ ${order.items.length - 1} lainnya` : '' %>
              </h4>
              <div class="active-order-services">
                <% order.items[0].addons.forEach(function(addon) { %>
                  <span class="service-badge"><%= addon.toUpperCase() %></span>
                <% }) %>
                <span class="service-badge"><%= order.items[0].serviceType.toUpperCase() %></span>
              </div>
            </div>
            <div class="active-order-status-wrap">
              <span class="active-order-status-label">STATUS</span>
              <span class="active-order-status">
                <i class="fa-solid fa-circle"></i> <%= order.statusLabel %>
              </span>
            </div>
          </div>

          <div class="active-order-progress">
            <div class="progress-header">
              <span class="progress-label">TOTAL HARGA</span>
              <span class="progress-pct">Rp <%= order.totalPrice.toLocaleString('id-ID') %></span>
            </div>
            <div class="progress-bar">
              <% 
                let progress = 10;
                let effectiveStatus = order.status;
                
                // If delivery is self and status is quality-check, it means it's ready to pickup!
                if (order.logistics && order.logistics.deliveryMethod === 'self' && effectiveStatus === 'quality-check') {
                  effectiveStatus = 'ready-to-pickup';
                }

                if (effectiveStatus === 'received') effectiveStatus = 'pickup';
                else if (effectiveStatus === 'ready-to-pickup') effectiveStatus = 'delivery';
                else if (effectiveStatus === 'payment-cod') effectiveStatus = 'delivery';

                if (effectiveStatus === 'payment') progress = 20;
                else if (effectiveStatus === 'pickup') progress = 35;
                else if (effectiveStatus === 'validating-in') progress = 50;
                else if (effectiveStatus === 'in-progress') progress = 65;
                else if (effectiveStatus === 'quality-check') progress = 80;
                else if (effectiveStatus === 'delivery') progress = 90;
              %>
              <div class="progress-fill" data-progress="<%= progress %>"></div>
            </div>
          </div>

            <div class="active-order-bottom">
              <div class="active-order-estimate">
                <i class="fa-regular fa-calendar"></i>
                <div>
                  <span class="estimate-label">TANGGAL PESAN</span>
                  <span class="estimate-value"><%= new Date(order.createdAt).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }) %></span>
                </div>
              </div>
              <div style="display: flex; gap: 8px; align-items: center;">
                <a href="/customer/order-detail?id=<%= order._id %>" class="btn btn-primary btn-sm">DETAIL</a>
              </div>
            </div>
        </div>
      </div>
    <% }) %>
  <% } %>
</div>

<!-- RIWAYAT PESANAN -->
<div class="orders-section" id="history-orders-section">
  <h3 class="dash-subtitle dash-subtitle--upper">RIWAYAT PESANAN</h3>

  <% const historyOrders = orders.filter(function(o) { return ["completed", "cancelled"].includes(o.status) }) %>
  
  <div class="history-grid">
    <% if (historyOrders.length === 0) { %>
      <p class="empty-text">Belum ada riwayat pesanan.</p>
    <% } else { %>
      <% historyOrders.forEach(function(order) { %>
        <div class="history-card" data-order-status="<%= order.status === 'completed' ? 'selesai' : 'batal' %>">
          <div class="history-card-top">
            <% 
              let shoePhoto = '/images/hero-shoe.png';
              if (order.items && order.items.length > 0) {
                const item = order.items[0];
                if (item.photosAfter && item.photosAfter.length > 0) {
                  shoePhoto = item.photosAfter[0];
                } else if (item.photosBefore && item.photosBefore.length > 0) {
                  shoePhoto = item.photosBefore[0];
                } else {
                  const qcPhoto = (order.statusHistory.find(h => h.status === 'quality-check') || {}).photos;
                  const valPhoto = (order.statusHistory.find(h => h.status === 'validating-in') || {}).photos;
                  if (qcPhoto && qcPhoto.length > 0) {
                    shoePhoto = qcPhoto[0];
                  } else if (valPhoto && valPhoto.length > 0) {
                    shoePhoto = valPhoto[0];
                  }
                }
              }
            %>
            <img src="<%= shoePhoto %>" alt="Sepatu" class="history-card-img" />
            <div class="history-card-info">
              <span class="history-card-id">#<%= order.orderId %></span>
              <span class="history-status-badge <%= order.status === 'cancelled' ? 'history-status-badge--cancelled' : '' %>">
                <%= order.statusLabel.toUpperCase() %>
              </span>
              <h4 class="history-card-name"><%= order.items[0].shoeName %></h4>
              <span class="history-card-service">
                <%= order.items[0].serviceType %> • <%= new Date(order.createdAt).toLocaleDateString('id-ID') %>
              </span>
            </div>
          </div>
          <a href="/customer/order-detail?id=<%= order._id %>" class="btn btn-outline-dark btn-sm history-btn">Lihat Detail</a>
        </div>
      <% }) %>
    <% } %>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Progress bar fill
    document.querySelectorAll('.progress-fill').forEach(el => {
      if (el.dataset.progress) {
        el.style.width = el.dataset.progress + '%';
      }
    });

    // Interactive filter tabs
    const tabs = document.querySelectorAll('.order-tab');
    const activeCards = document.querySelectorAll('.active-order-card');
    const historyCards = document.querySelectorAll('.history-card');
    const activeSection = document.getElementById('active-orders-section');
    const historySection = document.getElementById('history-orders-section');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');

        const filter = tab.dataset.filter;

        if (filter === 'all') {
          activeSection.style.display = 'block';
          historySection.style.display = 'block';
          activeCards.forEach(c => c.style.display = 'flex');
          historyCards.forEach(c => c.style.display = 'flex');
        } else if (filter === 'proses') {
          activeSection.style.display = 'block';
          historySection.style.display = 'none';
          activeCards.forEach(c => c.style.display = 'flex');
        } else if (filter === 'selesai') {
          activeSection.style.display = 'none';
          historySection.style.display = 'block';
          historyCards.forEach(c => {
            if (c.dataset.orderStatus === 'selesai') {
              c.style.display = 'flex';
            } else {
              c.style.display = 'none';
            }
          });
        } else if (filter === 'batal') {
          activeSection.style.display = 'none';
          historySection.style.display = 'block';
          historyCards.forEach(c => {
            if (c.dataset.orderStatus === 'batal') {
              c.style.display = 'flex';
            } else {
              c.style.display = 'none';
            }
          });
        }
      });
    });
  });
</script>

<%- include('../partials/dashboard-foot') %>
